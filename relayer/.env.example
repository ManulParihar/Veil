# Poof relayer configuration (all via env; matches the indexer's 12-factor story).

# REQUIRED — the relayer's own Stellar secret. It pays the network fee for each
# relayed withdraw and receives the in-proof relayer fee. Fund it via friendbot on
# testnet. This is a low-stakes hot wallet — NEVER an admin/issuer key.
POOF_RELAYER_SECRET=S...

# REQUIRED — the deployed Poof contract id.
POOF_CONTRACT_ID=CDVNLQYWDDH4BJQJBIOWW2CJELVR62FGGVPQN3ZMUNS7PUCIWH3SBLPN

# Optional (sane testnet defaults shown).
POOF_RPC_URL=https://soroban-testnet.stellar.org
POOF_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
# Minimum in-proof fee the relayer will accept, in base units (stroops). 0.1 XLM:
POOF_MIN_FEE=1000000
# Stellar tx fee the relayer is willing to pay (stroops).
POOF_BASE_FEE=1000000
# Bind port (Railway/Fly inject PORT automatically — don't set it there).
PORT=8787
